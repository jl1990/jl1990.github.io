---
import {EMAIL} from "../constants";

const navItems = [
    {
        title: "Experience",
        label: "experience",
        url: "/#experience",
    },
    {
        title: "About me",
        label: "about-me",
        url: "/#about-me",
    },
    {
        title: "Contact",
        label: "contact",
        url: 'mailto:' + EMAIL,
    },
]
---

<header
  class="fixed top-0 z-10 flex items-center justify-center w-full mx-auto mt-2"
>
  <nav
    class="flex px-3 text-sm font-medium rounded-full text-gray-600 dark:text-gray-200 justify-center items-center"
  >
    {
      navItems.map((link) => (
        <a
          class="relative block px-2 py-2 transition hover:text-blue-500 dark:hover:text-blue-500"
          aria-label={link.label}
          href={link.url}
        >
          {link.title}
        </a>
      ))
    }
  </nav>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const globalWindow = window as Window & { __headerNavCleanup?: () => void }
    globalWindow.__headerNavCleanup?.()

    const navItems = Array.from(document.querySelectorAll<HTMLAnchorElement>("header nav a"))
    const sectionLinks = navItems
      .map((item) => {
        const href = item.getAttribute("href") ?? ""
        const hashIndex = href.indexOf("#")

        if (hashIndex === -1) return null

        const id = href.slice(hashIndex + 1)
        if (!id) return null

        return { id, item }
      })
      .filter((entry): entry is { id: string; item: HTMLAnchorElement } => Boolean(entry))

    const sections = sectionLinks
      .map(({ id }) => document.getElementById(id))
      .filter((section): section is HTMLElement => Boolean(section))

    if (!sections.length) return

    let activeId = ""

    const setActive = (id: string) => {
      if (!id || id === activeId) return
      activeId = id

      sectionLinks.forEach(({ id: sectionId, item }) => {
        const isActive = sectionId === id
        item.classList.remove("text-blue-500")
        item.classList.toggle("!text-blue-500", isActive)
        if (isActive) {
          item.setAttribute("aria-current", "true")
        } else {
          item.removeAttribute("aria-current")
        }
      })
    }

    const syncFromHash = () => {
      const hashId = window.location.hash.replace("#", "")
      if (!hashId) return
      if (sections.some((section) => section.id === hashId)) {
        setActive(hashId)
      }
    }

    const updateActive = () => {
      const markerY = window.scrollY + window.innerHeight * 0.5
      let candidateId = sections[0]?.id ?? ""

      for (const section of sections) {
        const sectionTop = section.getBoundingClientRect().top + window.scrollY
        if (markerY >= sectionTop) {
          candidateId = section.id
        } else {
          break
        }
      }

      const isNearPageBottom =
        window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 2
      if (isNearPageBottom) {
        candidateId = sections[sections.length - 1]?.id ?? candidateId
      }

      if (candidateId) setActive(candidateId)
    }

    let rafId = 0
    const onScrollOrResize = () => {
      if (rafId) return
      rafId = window.requestAnimationFrame(() => {
        rafId = 0
        updateActive()
      })
    }

    const onNavClick = (event: Event) => {
      const currentTarget = event.currentTarget
      if (!(currentTarget instanceof HTMLAnchorElement)) return

      const href = currentTarget.getAttribute("href") ?? ""
      const hashIndex = href.indexOf("#")
      if (hashIndex === -1) return

      const id = href.slice(hashIndex + 1)
      if (!id) return
      setActive(id)
    }

    sectionLinks.forEach(({ item }) => {
      item.addEventListener("click", onNavClick)
    })

    window.addEventListener("scroll", onScrollOrResize, { passive: true })
    window.addEventListener("resize", onScrollOrResize)
    updateActive()
    syncFromHash()
    window.addEventListener("hashchange", syncFromHash)

    globalWindow.__headerNavCleanup = () => {
      if (rafId) {
        window.cancelAnimationFrame(rafId)
      }
      window.removeEventListener("scroll", onScrollOrResize)
      window.removeEventListener("resize", onScrollOrResize)
      window.removeEventListener("hashchange", syncFromHash)
      sectionLinks.forEach(({ item }) => {
        item.removeEventListener("click", onNavClick)
      })
    }
  })
</script>

<style>
  nav {
    --nav-bg: rgb(255 255 255 / 0.5);
    --nav-ring: rgb(255 255 255 / 0.1);
    animation: nav-shadown 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
    background-color: var(--nav-bg);
  }

  @keyframes nav-shadown {
    0% {
      background-color: transparent;
      box-shadow: none;
      backdrop-filter: blur(0);
      -webkit-backdrop-filter: blur(0);
    }
    to {
      background-color: var(--nav-bg);
      box-shadow:
        0 0 0 1px var(--nav-ring),
        0 10px 15px -3px rgb(0 0 0 / 0.1),
        0 4px 6px -4px rgb(0 0 0 / 0.1);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
  }

  :global(.dark) nav {
    --nav-bg: rgb(31 41 55 / 0.9);
  }
</style>
