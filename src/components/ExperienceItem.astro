---
interface Props {
    title: string
    company: string
    description: string
    link?: string
    date: string
    dateTime?: string
    domain?: string
}

const { title, company, description, link, date, dateTime, domain } = Astro.props
const logoUrl = domain ? `https://www.google.com/s2/favicons?domain=${domain}&sz=64` : null
---

<div
    class="relative mx-8 md:mx-12 pb-12 grid before:absolute before:left-[-35px] before:block before:h-full before:border-l-2 before:border-white/15 before:content-[''] md:grid-cols-5 md:gap-10"
>
    <div class="relative pb-4 md:col-span-2">
        <div class="md:sticky md:top-24">
            <span aria-hidden="true" class="text-yellow-400 -left-[42px] absolute rounded-full text-5xl leading-none">&bull;</span>
            <div class="flex items-start gap-3">
                {
                    logoUrl && (
                        <img
                            src={logoUrl}
                            alt=""
                            width="32"
                            height="32"
                            loading="lazy"
                            decoding="async"
                            class="mt-1 h-8 w-8 shrink-0 rounded-md border border-white/10 bg-white/90 p-1 object-contain"
                        />
                    )
                }
                <div class="min-w-0">
                    <h3 class="text-xl font-bold text-yellow-400">{title}</h3>
                    <h4 class="font-semibold text-xl text-white">
                        {link ? (
                            <a
                                href={link}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center text-lg font-medium rounded-sm hover:text-yellow-200 focus:outline-none focus-visible:ring focus-visible:ring-yellow-500/80 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950"
                            >
                                {company}
                            </a>
                        ) : (
                            <span class="inline-flex items-center text-lg font-medium">{company}</span>
                        )}
                    </h4>
                    <time datetime={dateTime} class="p-0 m-0 text-sm text-white/70">{date}</time>
                </div>
            </div>
        </div>
    </div>
    <div class="relative flex flex-col gap-2 pb-4 text-gray-300 md:col-span-3">
        {description}
    </div>
</div>
