---
import Layout from "@/layouts/Layout.astro"
import SectionContainer from "@/components/SectionContainer.astro"
---

<Layout
    title="Page not found — Juan Luis Carrasco"
    description="The page you were looking for could not be found."
>
    <main id="main-content" class="px-4">
        <SectionContainer class="py-32 md:py-44 text-center">
            <p class="text-sm font-mono text-yellow-200/80 tracking-widest uppercase">Error 404</p>
            <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl text-white">
                This page wandered off
            </h1>
            <p class="mt-4 max-w-md mx-auto text-gray-300">
                The link you followed might be broken, or the page may have been moved.
            </p>
            <a
                href="/"
                class="mt-8 inline-flex items-center gap-2 rounded-full border border-gray-600 bg-gray-800 px-5 py-2 text-sm text-white transition hover:bg-gray-100 hover:text-black focus:outline-none focus-visible:ring focus-visible:ring-yellow-500/80 focus-visible:ring-offset-2 focus-visible:ring-offset-gray-950"
            >
                &larr; Back home
            </a>
        </SectionContainer>
    </main>
</Layout>
